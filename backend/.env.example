# ---- GeoAttend Pro Backend Environment ----
APP_NAME="GeoAttend Pro"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/GeoAttendPro/backend/public
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=geoattend_pro
DB_USER=root
DB_PASS=

# Security
SESSION_TIMEOUT_HOURS=5
PASSWORD_RESET_TTL_MINUTES=60

# Mail (PHPMailer / SMTP). Leave host empty to log mails to storage/logs/mail.log
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@geoattend.test
MAIL_FROM_NAME="GeoAttend Pro"
