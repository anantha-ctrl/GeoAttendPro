# Route every request through index.php (except real files in /storage etc.)
RewriteEngine On

# Pass the Authorization header through to PHP. Apache (mod_php/CGI) strips it by
# default, which would break Bearer-token auth on every protected request.
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%1]
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>
# Apache 2.4.13+ : also expose Authorization directly to PHP
CGIPassAuth On

# Allow direct access to uploaded files served from storage symlink/alias
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [QSA,L]

# Basic hardening
Options -Indexes
<FilesMatch "\.(env|sql|log)$">
    Require all denied
</FilesMatch>
